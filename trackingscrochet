<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Invisible Labor — Crochet AR</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Courier+Prime:ital,wght@0,400;0,700;1,400&display=swap');

:root {
  --flow: #5B8FA8;
  --flow-warm: #A8C5D6;
  --rest: #C4A882;
  --rest-warm: #E8D5B8;
  --burnout: #B85042;
  --burnout-warm: #D4847A;
  --void: #0D0B09;
  --parchment: #F2E8D5;
  --ink: #2A2218;
  --thread-gold: #C8963C;
  --thread-shadow: rgba(200,150,60,0.15);
}

* { margin:0; padding:0; box-sizing:border-box; }

html, body {
  width:100%; height:100%;
  background: var(--void);
  overflow: hidden;
  font-family: 'Courier Prime', monospace;
  color: var(--parchment);
}

/* ── AR CAMERA LAYER ── */
#ar-container {
  position: fixed;
  inset: 0;
  z-index: 0;
}

#webcam {
  position: absolute;
  inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  transform: scaleX(-1);
  filter: saturate(0.6) brightness(0.55);
}

/* AR overlay canvas — sits on top of video */
#ar-canvas {
  position: absolute;
  inset: 0;
  width: 100%; height: 100%;
  z-index: 2;
  transform: scaleX(-1);
}

/* Vignette framing */
#vignette {
  position: absolute;
  inset: 0;
  z-index: 3;
  background: radial-gradient(ellipse 75% 75% at 50% 50%, transparent 40%, rgba(13,11,9,0.85) 100%);
  pointer-events: none;
}

/* ── STATE ATMOSPHERE ── */
#atmosphere {
  position: fixed;
  inset: 0;
  z-index: 4;
  pointer-events: none;
  opacity: 0;
  transition: opacity 2s ease;
  mix-blend-mode: color-dodge;
}

/* ── UI LAYER ── */
#ui {
  position: fixed;
  inset: 0;
  z-index: 10;
  pointer-events: none;
}

/* Title */
#header {
  position: absolute;
  top: 32px; left: 40px;
  pointer-events: none;
}

#header h1 {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
  font-style: italic;
  font-size: clamp(20px, 2.5vw, 32px);
  letter-spacing: 0.06em;
  color: rgba(242,232,213,0.9);
  line-height: 1;
}

#header .sub {
  margin-top: 5px;
  font-size: 8px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: rgba(200,150,60,0.6);
}

/* State Readout — top right */
#state-readout {
  position: absolute;
  top: 28px; right: 40px;
  text-align: right;
}

#state-word {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
  font-style: italic;
  font-size: clamp(32px, 5vw, 64px);
  letter-spacing: -0.02em;
  line-height: 1;
  transition: color 2s ease, text-shadow 2s ease;
  color: var(--rest);
}

#state-desc {
  font-size: 8px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: rgba(242,232,213,0.35);
  margin-top: 6px;
  transition: opacity 1s ease;
  max-width: 260px;
  text-align: right;
  line-height: 1.9;
}

/* Labor log — bottom left */
#labor-log {
  position: absolute;
  bottom: 36px; left: 40px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.log-row {
  display: flex;
  align-items: center;
  gap: 14px;
}

.log-label {
  font-size: 7px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: rgba(242,232,213,0.3);
  width: 68px;
}

.log-bar-wrap {
  width: 100px;
  height: 1px;
  background: rgba(255,255,255,0.06);
  position: relative;
}

.log-bar-fill {
  position: absolute;
  left: 0; top: 0;
  height: 100%;
  transition: width 0.5s ease, background 1.5s ease;
}

.log-num {
  font-size: 8px;
  color: rgba(242,232,213,0.3);
  width: 30px;
  text-align: right;
}

/* Stitch ticker */
#stitch-ticker {
  position: absolute;
  bottom: 36px; right: 40px;
  text-align: right;
}

#stitch-num {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
  font-style: italic;
  font-size: clamp(40px, 6vw, 80px);
  color: rgba(200,150,60,0.12);
  line-height: 1;
  transition: color 0.3s ease;
}

#stitch-label {
  font-size: 7px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: rgba(200,150,60,0.25);
  margin-top: 4px;
}

/* AR gesture markers — positioned by JS */
.gesture-tag {
  position: absolute;
  pointer-events: none;
  display: flex;
  align-items: center;
  gap: 8px;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.gesture-tag.visible { opacity: 1; }

.gesture-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

.gesture-text {
  font-size: 8px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  white-space: nowrap;
}

/* Story caption — center bottom */
#story-caption {
  position: absolute;
  bottom: 120px;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
  width: 500px;
  max-width: 90vw;
  pointer-events: none;
  opacity: 0;
  transition: opacity 1.5s ease;
}

#story-caption p {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: clamp(13px, 1.5vw, 17px);
  font-weight: 300;
  line-height: 1.9;
  color: rgba(242,232,213,0.55);
  letter-spacing: 0.03em;
}

/* Thread path canvas — for drawing trails */
#thread-canvas {
  position: fixed;
  inset: 0;
  z-index: 8;
  pointer-events: none;
  width: 100%; height: 100%;
}

/* Onboarding screen */
#onboard {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: var(--void);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20px;
  transition: opacity 1.2s ease;
}

#onboard h2 {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
  font-style: italic;
  font-size: clamp(28px, 5vw, 52px);
  color: var(--parchment);
  text-align: center;
  line-height: 1.2;
  letter-spacing: 0.03em;
}

#onboard .tagline {
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: rgba(200,150,60,0.5);
  text-align: center;
}

#onboard .instructions {
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(242,232,213,0.25);
  text-align: center;
  line-height: 2.5;
  max-width: 420px;
}

#start-btn {
  margin-top: 12px;
  background: transparent;
  border: 1px solid rgba(200,150,60,0.4);
  color: rgba(200,150,60,0.8);
  font-family: 'Courier Prime', monospace;
  font-size: 9px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  padding: 14px 36px;
  cursor: pointer;
  transition: all 0.3s ease;
  pointer-events: all;
}

#start-btn:hover {
  background: rgba(200,150,60,0.08);
  border-color: rgba(200,150,60,0.8);
  color: var(--thread-gold);
}

/* Grain overlay */
#grain {
  position: fixed;
  inset: 0;
  z-index: 99;
  pointer-events: none;
  opacity: 0.025;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 200px 200px;
}

/* Scanner line — AR effect */
#scanner {
  position: fixed;
  left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(200,150,60,0.08), transparent);
  z-index: 9;
  pointer-events: none;
  animation: scan 8s linear infinite;
  opacity: 0;
  transition: opacity 1s ease;
}

@keyframes scan {
  0%   { top: -1px; }
  100% { top: 100%; }
}

/* Gesture event flash */
#event-flash {
  position: fixed;
  inset: 0;
  z-index: 7;
  pointer-events: none;
  opacity: 0;
}

/* Corner brackets — AR framing */
.corner {
  position: fixed;
  z-index: 11;
  width: 24px; height: 24px;
  pointer-events: none;
  opacity: 0.25;
}
.corner.tl { top: 24px; left: 24px; border-top: 1px solid var(--thread-gold); border-left: 1px solid var(--thread-gold); }
.corner.tr { top: 24px; right: 24px; border-top: 1px solid var(--thread-gold); border-right: 1px solid var(--thread-gold); }
.corner.bl { bottom: 24px; left: 24px; border-bottom: 1px solid var(--thread-gold); border-left: 1px solid var(--thread-gold); }
.corner.br { bottom: 24px; right: 24px; border-bottom: 1px solid var(--thread-gold); border-right: 1px solid var(--thread-gold); }

/* Knot counter marks */
#knot-marks {
  position: fixed;
  top: 50%;
  left: 20px;
  transform: translateY(-50%);
  z-index: 11;
  display: flex;
  flex-direction: column;
  gap: 5px;
  pointer-events: none;
}

.knot-mark {
  width: 3px; height: 3px;
  border-radius: 50%;
  background: rgba(200,150,60,0.3);
  transition: background 0.5s ease, transform 0.3s ease;
}
.knot-mark.active {
  background: var(--thread-gold);
  transform: scale(1.5);
}
</style>
</head>
<body>

<div id="grain"></div>
<div class="corner tl"></div>
<div class="corner tr"></div>
<div class="corner bl"></div>
<div class="corner br"></div>
<div id="scanner"></div>

<!-- AR camera + overlay -->
<div id="ar-container">
  <video id="webcam" autoplay muted playsinline></video>
  <canvas id="ar-canvas"></canvas>
  <div id="vignette"></div>
</div>

<canvas id="thread-canvas"></canvas>
<div id="event-flash"></div>
<div id="atmosphere"></div>

<!-- UI -->
<div id="ui">
  <div id="header">
    <h1>Invisible Labor</h1>
    <div class="sub">AR Crochet Gesture System</div>
  </div>

  <div id="state-readout">
    <div id="state-word">Rest</div>
    <div id="state-desc">Awaiting gesture — point camera at your hands or crochet work</div>
  </div>

  <div id="labor-log">
    <div class="log-row">
      <span class="log-label">Velocity</span>
      <div class="log-bar-wrap"><div class="log-bar-fill" id="bar-velocity" style="width:0%;background:var(--flow)"></div></div>
      <span class="log-num" id="num-velocity">0</span>
    </div>
    <div class="log-row">
      <span class="log-label">Rhythm</span>
      <div class="log-bar-wrap"><div class="log-bar-fill" id="bar-rhythm" style="width:0%;background:var(--thread-gold)"></div></div>
      <span class="log-num" id="num-rhythm">0</span>
    </div>
    <div class="log-row">
      <span class="log-label">Tension</span>
      <div class="log-bar-wrap"><div class="log-bar-fill" id="bar-tension" style="width:0%;background:var(--burnout)"></div></div>
      <span class="log-num" id="num-tension">0</span>
    </div>
    <div class="log-row">
      <span class="log-label">Fatigue</span>
      <div class="log-bar-wrap"><div class="log-bar-fill" id="bar-fatigue" style="width:0%;background:var(--rest)"></div></div>
      <span class="log-num" id="num-fatigue">0</span>
    </div>
  </div>

  <div id="stitch-ticker">
    <div id="stitch-num">0</div>
    <div id="stitch-label">gestures mapped</div>
  </div>

  <div id="story-caption"><p id="caption-text"></p></div>
</div>

<div id="knot-marks"></div>

<!-- Onboarding -->
<div id="onboard">
  <h2>Invisible Labor</h2>
  <p class="tagline">AR Crochet Gesture Tracker</p>
  <p class="instructions">
    Hold your crochet work up to the camera<br>
    Your gestures reveal hidden states of craft labor<br>
    — Flow · Rest · Burnout —<br>
    Slow pinch = hook &amp; pull · Open palm = rest<br>
    Rapid motion = flow state · Tremor = fatigue
  </p>
  <button id="start-btn" onclick="initCamera()">Begin</button>
</div>

<!-- MediaPipe Hands -->
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/drawing_utils/drawing_utils.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/hands/hands.js" crossorigin="anonymous"></script>

<script>
// ─────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────
const States = {
  REST:    'rest',
  FLOW:    'flow',
  BURNOUT: 'burnout'
};

const stateColors = {
  rest:    { primary: '#C4A882', warm: '#E8D5B8', bg: 'rgba(196,168,130,0.04)' },
  flow:    { primary: '#5B8FA8', warm: '#A8C5D6', bg: 'rgba(91,143,168,0.06)' },
  burnout: { primary: '#B85042', warm: '#D4847A', bg: 'rgba(184,80,66,0.07)' }
};

const stateDescriptions = {
  rest:    'The hands pause between stitches.\nMuscle memory settles.\nTime accumulates in the fiber.',
  flow:    'Rhythm found — the hook moves without thought.\nThe body knows this pattern.\nLabor becomes meditation.',
  burnout: 'The tension pulls too tight.\nFingers ache with repetition.\nThe work continues despite the body.'
};

const stateCaptions = {
  rest:    "Every pause holds the weight of the last stitch — the hands remember even when they rest.",
  flow:    "Here: the threshold where craft dissolves into the body. A thousand stitches, one unbroken motion.",
  burnout: "The hands continue what the spirit cannot. This, too, is woven into the fabric — invisible, indelible."
};

const stateGestures = {
  rest:    ['stillness', 'held breath', 'muscle memory'],
  flow:    ['hook', 'loop', 'pull through', 'chain'],
  burnout: ['overcorrection', 'tightened grip', 'missed stitch']
};

let currentState = States.REST;
let prevState = null;
let stitchCount = 0;
let velocity = 0;
let rhythm = 0;
let tension = 0;
let fatigue = 0;
let frameCount = 0;
let handHistory = [];
let landmarkHistory = [];
let lastGestureTime = 0;
let gestureEvents = [];
let threadParticles = [];
let knotCount = 0;
let captionTimeout = null;

// ─────────────────────────────────────────────
// CANVAS SETUP
// ─────────────────────────────────────────────
const arCanvas = document.getElementById('ar-canvas');
const arCtx = arCanvas.getContext('2d');
const threadCanvas = document.getElementById('thread-canvas');
const tCtx = threadCanvas.getContext('2d');

function resizeCanvases() {
  arCanvas.width = window.innerWidth;
  arCanvas.height = window.innerHeight;
  threadCanvas.width = window.innerWidth;
  threadCanvas.height = window.innerHeight;
}
window.addEventListener('resize', resizeCanvases);
resizeCanvases();

// ─────────────────────────────────────────────
// KNOT MARKS
// ─────────────────────────────────────────────
function buildKnotMarks() {
  const el = document.getElementById('knot-marks');
  for (let i = 0; i < 20; i++) {
    const d = document.createElement('div');
    d.className = 'knot-mark';
    d.id = `knot-${i}`;
    el.appendChild(d);
  }
}
buildKnotMarks();

function updateKnotMarks() {
  const n = Math.min(knotCount, 20);
  for (let i = 0; i < 20; i++) {
    document.getElementById(`knot-${i}`).classList.toggle('active', i < n);
  }
}

// ─────────────────────────────────────────────
// GESTURE DETECTION
// ─────────────────────────────────────────────
function getLandmarkPos(lms, idx) {
  return { x: lms[idx].x * window.innerWidth, y: lms[idx].y * window.innerHeight };
}

function dist(a, b) {
  return Math.hypot(a.x - b.x, a.y - b.y);
}

function detectCrochetGesture(landmarks) {
  // Key points
  const thumb  = getLandmarkPos(landmarks, 4);
  const index  = getLandmarkPos(landmarks, 8);
  const middle = getLandmarkPos(landmarks, 12);
  const ring   = getLandmarkPos(landmarks, 16);
  const pinky  = getLandmarkPos(landmarks, 20);
  const wrist  = getLandmarkPos(landmarks, 0);
  const thumbMcp = getLandmarkPos(landmarks, 2);
  const indexMcp = getLandmarkPos(landmarks, 5);

  const pinchDist = dist(thumb, index);
  const handSpan = dist(wrist, middle);
  const pinchRatio = pinchDist / handSpan;

  // Finger extension: tip vs mcp height
  function fingerExtended(tipIdx, mcpIdx) {
    return landmarks[tipIdx].y < landmarks[mcpIdx].y - 0.05;
  }

  const indexExt  = fingerExtended(8, 5);
  const middleExt = fingerExtended(12, 9);
  const ringExt   = fingerExtended(16, 13);
  const pinkyExt  = fingerExtended(20, 17);
  const thumbExt  = landmarks[4].x < landmarks[3].x - 0.03 || landmarks[4].x > landmarks[3].x + 0.03;

  const allOpen = indexExt && middleExt && ringExt && pinkyExt;
  const hook    = pinchRatio < 0.22;  // thumb + index pinch = hook
  const pullThrough = hook && !middleExt;
  const chain   = pinchRatio < 0.35 && middleExt && !ringExt;
  const openPalm = allOpen && pinchRatio > 0.4;
  const fist    = !indexExt && !middleExt && !ringExt && !pinkyExt;

  return { pinchRatio, openPalm, hook, pullThrough, chain, fist, allOpen,
           thumb, index, middle, ring, pinky, wrist,
           positions: { thumb, index, middle, ring, pinky, wrist } };
}

function computeHandVelocity(landmarks) {
  const wrist = getLandmarkPos(landmarks, 0);
  handHistory.push(wrist);
  if (handHistory.length > 12) handHistory.shift();
  if (handHistory.length < 3) return 0;
  let totalDist = 0;
  for (let i = 1; i < handHistory.length; i++) {
    totalDist += dist(handHistory[i], handHistory[i-1]);
  }
  return totalDist / handHistory.length;
}

function detectRhythm() {
  // Rhythm = regularity of pinch events
  if (gestureEvents.length < 3) return 0;
  const intervals = [];
  for (let i = 1; i < Math.min(gestureEvents.length, 8); i++) {
    intervals.push(gestureEvents[i] - gestureEvents[i-1]);
  }
  const mean = intervals.reduce((a,b)=>a+b,0) / intervals.length;
  const variance = intervals.reduce((a,b)=>a+Math.pow(b-mean,2),0) / intervals.length;
  const cv = Math.sqrt(variance) / mean; // coefficient of variation
  return Math.max(0, Math.min(1, 1 - cv)); // 1 = perfectly rhythmic
}

// ─────────────────────────────────────────────
// STATE TRANSITIONS
// ─────────────────────────────────────────────
function determineState(vel, rhy, ten, fat) {
  if (vel < 5 && ten < 0.2) return States.REST;
  if (rhy > 0.55 && vel > 8 && vel < 55 && fat < 0.55) return States.FLOW;
  if (fat > 0.62 || ten > 0.7 || vel > 60) return States.BURNOUT;
  if (vel > 6) return States.FLOW;
  return States.REST;
}

function transitionState(newState) {
  if (newState === currentState) return;
  prevState = currentState;
  currentState = newState;

  const c = stateColors[newState];
  document.getElementById('state-word').style.color = c.primary;
  document.getElementById('state-word').textContent = newState.charAt(0).toUpperCase() + newState.slice(1);
  document.getElementById('state-desc').textContent = stateDescriptions[newState];
  document.getElementById('atmosphere').style.background = c.bg;
  document.getElementById('atmosphere').style.opacity = 1;
  document.getElementById('event-flash').style.background = c.bg;
  document.getElementById('event-flash').style.opacity = 0.18;
  setTimeout(() => { document.getElementById('event-flash').style.transition = 'opacity 1.2s ease';
                     document.getElementById('event-flash').style.opacity = 0; }, 80);

  showCaption(stateCaptions[newState]);

  if (newState === States.FLOW) knotCount = Math.min(knotCount + 1, 20);
  if (newState === States.BURNOUT) spawnBurnoutParticles();
  updateKnotMarks();
}

// ─────────────────────────────────────────────
// STORY CAPTION
// ─────────────────────────────────────────────
function showCaption(text) {
  const el = document.getElementById('story-caption');
  const p = document.getElementById('caption-text');
  clearTimeout(captionTimeout);
  el.style.opacity = 0;
  setTimeout(() => {
    p.textContent = text;
    el.style.opacity = 1;
    captionTimeout = setTimeout(() => { el.style.opacity = 0; }, 5000);
  }, 400);
}

// ─────────────────────────────────────────────
// METRICS UI
// ─────────────────────────────────────────────
function updateMetricsUI() {
  const v = Math.min(100, Math.round(velocity * 1.5));
  const r = Math.round(rhythm * 100);
  const te = Math.round(tension * 100);
  const fa = Math.round(fatigue * 100);

  document.getElementById('bar-velocity').style.width = v + '%';
  document.getElementById('bar-velocity').style.background = stateColors[currentState].primary;
  document.getElementById('num-velocity').textContent = v;
  document.getElementById('bar-rhythm').style.width = r + '%';
  document.getElementById('num-rhythm').textContent = r;
  document.getElementById('bar-tension').style.width = te + '%';
  document.getElementById('num-tension').textContent = te;
  document.getElementById('bar-fatigue').style.width = fa + '%';
  document.getElementById('num-fatigue').textContent = fa;
  document.getElementById('stitch-num').textContent = stitchCount;
  document.getElementById('stitch-num').style.color = velocity > 8
    ? `rgba(200,150,60,0.35)` : `rgba(200,150,60,0.1)`;
}

// ─────────────────────────────────────────────
// PARTICLE SYSTEM
// ─────────────────────────────────────────────
class ThreadParticle {
  constructor(x, y, state, type='thread') {
    this.x = x; this.y = y;
    this.state = state; this.type = type;
    this.vx = (Math.random()-0.5)*2;
    this.vy = (Math.random()-0.5)*2 - 0.5;
    this.life = 1;
    this.maxLife = 0.6 + Math.random()*0.8;
    this.size = type === 'knot' ? 3 + Math.random()*4 : 1 + Math.random()*2;
    this.length = type === 'thread' ? 8 + Math.random()*20 : 0;
    this.angle = Math.random() * Math.PI * 2;
    this.angularVel = (Math.random()-0.5)*0.08;
    this.c = stateColors[state];
  }
  update() {
    this.x += this.vx;
    this.y += this.vy;
    this.vy += 0.01;
    this.angle += this.angularVel;
    this.life -= 0.012;
    return this.life > 0;
  }
  draw(ctx) {
    const a = this.life;
    ctx.save();
    ctx.globalAlpha = a * 0.7;
    ctx.translate(this.x, this.y);
    ctx.rotate(this.angle);
    if (this.type === 'thread') {
      ctx.strokeStyle = this.c.primary;
      ctx.lineWidth = this.size * 0.5;
      ctx.lineCap = 'round';
      ctx.beginPath();
      ctx.moveTo(-this.length/2, 0);
      ctx.bezierCurveTo(-this.length/4, -this.size, this.length/4, this.size, this.length/2, 0);
      ctx.stroke();
    } else if (this.type === 'knot') {
      ctx.fillStyle = this.c.warm;
      ctx.beginPath();
      for (let i=0;i<5;i++) {
        const ang = (i*4*Math.PI/5) - Math.PI/2;
        const r = i===0 ? this.size : this.size*0.4;
        if (i===0) ctx.moveTo(Math.cos(ang)*r, Math.sin(ang)*r);
        else ctx.lineTo(Math.cos(ang)*r, Math.sin(ang)*r);
      }
      ctx.closePath();
      ctx.fill();
    } else {
      // tension shard
      ctx.strokeStyle = '#B85042';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(0, -this.size*2);
      ctx.lineTo(this.size*0.5, this.size);
      ctx.lineTo(-this.size*0.5, this.size);
      ctx.closePath();
      ctx.stroke();
    }
    ctx.restore();
  }
}

function spawnGestureParticles(x, y, state, count=6) {
  for (let i = 0; i < count; i++) {
    const type = state === States.FLOW ? (Math.random()>0.5?'thread':'knot')
                : state === States.BURNOUT ? (Math.random()>0.3?'shard':'thread')
                : 'thread';
    threadParticles.push(new ThreadParticle(x, y, state, type));
  }
}

function spawnBurnoutParticles() {
  const cx = window.innerWidth * 0.5;
  const cy = window.innerHeight * 0.5;
  for (let i = 0; i < 20; i++) {
    const angle = Math.random() * Math.PI * 2;
    const r = 50 + Math.random() * 200;
    threadParticles.push(new ThreadParticle(
      cx + Math.cos(angle)*r, cy + Math.sin(angle)*r, States.BURNOUT, 'shard'
    ));
  }
}

// ─────────────────────────────────────────────
// THREAD TRAIL — persistent drawing
// ─────────────────────────────────────────────
let trailPoints = [];
const MAX_TRAIL = 120;

function addTrailPoint(x, y, state) {
  trailPoints.push({ x, y, state, age: 0 });
  if (trailPoints.length > MAX_TRAIL) trailPoints.shift();
}

function drawThreadTrail(ctx) {
  ctx.clearRect(0, 0, ctx.canvas.width, ctx.canvas.height);
  if (trailPoints.length < 2) return;

  for (let i = 1; i < trailPoints.length; i++) {
    const a = trailPoints[i-1];
    const b = trailPoints[i];
    const progress = i / trailPoints.length;
    const c = stateColors[b.state];
    ctx.beginPath();
    ctx.moveTo(a.x, a.y);

    // wavy crochet stitch line
    const dx = b.x - a.x, dy = b.y - a.y;
    const len = Math.hypot(dx, dy);
    if (len < 1) continue;
    const nx = -dy/len, ny = dx/len;
    const wave = Math.sin(i * 0.4) * 3;
    ctx.bezierCurveTo(
      a.x + nx*wave, a.y + ny*wave,
      b.x + nx*wave, b.y + ny*wave,
      b.x, b.y
    );
    ctx.strokeStyle = c.primary;
    ctx.globalAlpha = progress * 0.5;
    ctx.lineWidth = currentState === States.BURNOUT ? 1.5 : 1;
    ctx.lineCap = 'round';
    ctx.stroke();
    ctx.globalAlpha = 1;
  }
}

// ─────────────────────────────────────────────
// AR OVERLAY DRAWING
// ─────────────────────────────────────────────
function drawAROverlay(landmarks, gesture) {
  arCtx.clearRect(0, 0, arCanvas.width, arCanvas.height);
  const c = stateColors[currentState];
  const t = Date.now() * 0.001;

  // ── HAND SKELETON ──
  const connections = [
    [0,1],[1,2],[2,3],[3,4],
    [0,5],[5,6],[6,7],[7,8],
    [0,9],[9,10],[10,11],[11,12],
    [0,13],[13,14],[14,15],[15,16],
    [0,17],[17,18],[18,19],[19,20],
    [5,9],[9,13],[13,17]
  ];

  connections.forEach(([a,b]) => {
    const pa = getLandmarkPos(landmarks, a);
    const pb = getLandmarkPos(landmarks, b);
    arCtx.beginPath();
    arCtx.moveTo(pa.x, pa.y);
    arCtx.lineTo(pb.x, pb.y);
    arCtx.strokeStyle = c.primary;
    arCtx.globalAlpha = currentState === States.BURNOUT ? 0.25 : 0.18;
    arCtx.lineWidth = 0.8;
    arCtx.stroke();
    arCtx.globalAlpha = 1;
  });

  // ── FINGERTIP DOTS ──
  [4, 8, 12, 16, 20].forEach((idx, i) => {
    const p = getLandmarkPos(landmarks, idx);
    const pulse = 0.5 + 0.5 * Math.sin(t * 3 + i * 1.2);
    const r = currentState === States.FLOW ? 4 + pulse*3 : 3;
    arCtx.beginPath();
    arCtx.arc(p.x, p.y, r, 0, Math.PI*2);
    arCtx.fillStyle = c.warm;
    arCtx.globalAlpha = currentState === States.BURNOUT ? 0.4 + pulse*0.2 : 0.5;
    arCtx.fill();
    arCtx.globalAlpha = 1;
  });

  // ── PINCH INDICATOR ──
  if (gesture.hook) {
    const mx = (gesture.thumb.x + gesture.index.x) / 2;
    const my = (gesture.thumb.y + gesture.index.y) / 2;
    const r = 6 + Math.sin(t*8)*2;
    arCtx.beginPath();
    arCtx.arc(mx, my, r, 0, Math.PI*2);
    arCtx.strokeStyle = c.primary;
    arCtx.globalAlpha = 0.7;
    arCtx.lineWidth = 1.5;
    arCtx.stroke();
    arCtx.globalAlpha = 0.15;
    arCtx.fillStyle = c.primary;
    arCtx.fill();
    arCtx.globalAlpha = 1;

    // label
    arCtx.font = '7px "Courier Prime", monospace';
    arCtx.fillStyle = c.warm;
    arCtx.globalAlpha = 0.7;
    arCtx.letterSpacing = '0.2em';
    arCtx.fillText('hook', mx + 12, my - 8);
    arCtx.globalAlpha = 1;

    spawnGestureParticles(mx, my, currentState, 2);
    stitchCount++;
    gestureEvents.push(Date.now());
    if (gestureEvents.length > 12) gestureEvents.shift();
    lastGestureTime = Date.now();
  }

  // ── OPEN PALM = REST AURA ──
  if (gesture.openPalm) {
    const palm = getLandmarkPos(landmarks, 9);
    const r = 50 + Math.sin(t * 1.5) * 8;
    const grad = arCtx.createRadialGradient(palm.x, palm.y, 10, palm.x, palm.y, r);
    grad.addColorStop(0, `${c.primary}22`);
    grad.addColorStop(1, `${c.primary}00`);
    arCtx.beginPath();
    arCtx.arc(palm.x, palm.y, r, 0, Math.PI*2);
    arCtx.fillStyle = grad;
    arCtx.fill();
  }

  // ── FLOW STATE: spiraling thread around wrist ──
  if (currentState === States.FLOW) {
    const wrist = getLandmarkPos(landmarks, 0);
    arCtx.beginPath();
    for (let i = 0; i < 60; i++) {
      const a = (i / 60) * Math.PI * 4 + t;
      const r = 18 + i * 0.3;
      const x = wrist.x + Math.cos(a) * r;
      const y = wrist.y + Math.sin(a) * r * 0.5;
      if (i === 0) arCtx.moveTo(x, y); else arCtx.lineTo(x, y);
    }
    arCtx.strokeStyle = c.primary;
    arCtx.globalAlpha = 0.15;
    arCtx.lineWidth = 0.8;
    arCtx.stroke();
    arCtx.globalAlpha = 1;
  }

  // ── BURNOUT: shatter lines from fingertips ──
  if (currentState === States.BURNOUT) {
    [4, 8, 12].forEach((idx) => {
      const p = getLandmarkPos(landmarks, idx);
      for (let i = 0; i < 4; i++) {
        const a = t * 2 + i * Math.PI/2;
        const len = 12 + Math.sin(t*5+i)*6;
        arCtx.beginPath();
        arCtx.moveTo(p.x, p.y);
        arCtx.lineTo(p.x + Math.cos(a)*len, p.y + Math.sin(a)*len);
        arCtx.strokeStyle = '#B85042';
        arCtx.globalAlpha = 0.18 + Math.sin(t*3)*0.08;
        arCtx.lineWidth = 0.7;
        arCtx.stroke();
        arCtx.globalAlpha = 1;
      }
    });
  }

  // ── STITCH COUNT AR TAG ──
  if (stitchCount > 0) {
    const wrist = getLandmarkPos(landmarks, 0);
    arCtx.font = 'italic 11px "Cormorant Garamond", serif';
    arCtx.fillStyle = 'rgba(200,150,60,0.55)';
    arCtx.fillText(`${stitchCount} stitches`, wrist.x + 20, wrist.y + 20);
  }

  // Add to trail
  const tip = getLandmarkPos(landmarks, 8);
  addTrailPoint(tip.x, tip.y, currentState);
}

function drawIdleOverlay() {
  arCtx.clearRect(0, 0, arCanvas.width, arCanvas.height);
  const t = Date.now() * 0.001;
  const cx = arCanvas.width / 2, cy = arCanvas.height / 2;
  // gentle waiting ring
  arCtx.beginPath();
  arCtx.arc(cx, cy, 30 + Math.sin(t)*5, 0, Math.PI*2);
  arCtx.strokeStyle = 'rgba(200,150,60,0.1)';
  arCtx.lineWidth = 1;
  arCtx.stroke();
}

// ─────────────────────────────────────────────
// PARTICLES RENDER LOOP
// ─────────────────────────────────────────────
function renderParticles() {
  // threadCanvas is additive so we fade slowly
  tCtx.fillStyle = 'rgba(13,11,9,0.03)';
  tCtx.fillRect(0, 0, threadCanvas.width, threadCanvas.height);

  drawThreadTrail(tCtx);

  threadParticles = threadParticles.filter(p => {
    const alive = p.update();
    if (alive) p.draw(tCtx);
    return alive;
  });
}

// ─────────────────────────────────────────────
// MAIN LOOP
// ─────────────────────────────────────────────
let lastLandmarks = null;

function mainLoop() {
  frameCount++;

  // Decay fatigue/velocity over time
  const now = Date.now();
  const timeSinceGesture = (now - lastGestureTime) / 1000;

  if (lastLandmarks) {
    const vel = computeHandVelocity(lastLandmarks);
    velocity = velocity * 0.85 + vel * 0.15;
  } else {
    velocity *= 0.92;
  }

  // Fatigue accumulates with burnout, recovers with rest
  if (currentState === States.BURNOUT) fatigue = Math.min(1, fatigue + 0.003);
  else if (currentState === States.REST) fatigue = Math.max(0, fatigue - 0.005);
  else fatigue = Math.max(0, fatigue - 0.001);

  // Tension from erratic movement
  if (velocity > 55) tension = Math.min(1, tension + 0.04);
  else tension = Math.max(0, tension - 0.015);

  rhythm = detectRhythm();

  if (timeSinceGesture > 3) rhythm *= 0.95;

  const newState = determineState(velocity, rhythm, tension, fatigue);
  transitionState(newState);
  updateMetricsUI();

  renderParticles();
  if (!lastLandmarks) drawIdleOverlay();

  requestAnimationFrame(mainLoop);
}

// ─────────────────────────────────────────────
// MEDIAPIPE HANDS
// ─────────────────────────────────────────────
function onHandResults(results) {
  if (results.multiHandLandmarks && results.multiHandLandmarks.length > 0) {
    const lm = results.multiHandLandmarks[0];
    lastLandmarks = lm;
    const gesture = detectCrochetGesture(lm);
    drawAROverlay(lm, gesture);
    document.getElementById('gesture-hint') && (document.getElementById('gesture-hint').style.opacity = 0);
  } else {
    lastLandmarks = null;
    drawIdleOverlay();
  }
}

// ─────────────────────────────────────────────
// CAMERA INIT
// ─────────────────────────────────────────────
async function initCamera() {
  const onboard = document.getElementById('onboard');
  onboard.style.opacity = 0;
  setTimeout(() => { onboard.style.display = 'none'; }, 1200);
  document.getElementById('scanner').style.opacity = 1;
  document.getElementById('atmosphere').style.opacity = 1;

  try {
    const stream = await navigator.mediaDevices.getUserMedia({
      video: { width: { ideal: 1280 }, height: { ideal: 720 }, facingMode: 'user' }
    });
    const video = document.getElementById('webcam');
    video.srcObject = stream;
    video.play();

    const hands = new Hands({ locateFile: f =>
      `https://cdn.jsdelivr.net/npm/@mediapipe/hands/${f}` });
    hands.setOptions({
      maxNumHands: 1,
      modelComplexity: 1,
      minDetectionConfidence: 0.65,
      minTrackingConfidence: 0.55
    });
    hands.onResults(onHandResults);

    const camera = new Camera(video, {
      onFrame: async () => { await hands.send({ image: video }); },
      width: 1280, height: 720
    });
    camera.start();

    lastGestureTime = Date.now();
    showCaption("Point your hands and crochet work toward the camera to begin.");

  } catch(e) {
    console.warn('Camera unavailable, running demo mode:', e);
    startDemoMode();
  }

  mainLoop();
}

// ─────────────────────────────────────────────
// DEMO MODE (no camera)
// ─────────────────────────────────────────────
function startDemoMode() {
  document.getElementById('webcam').style.display = 'none';
  let demoT = 0;
  const demoPhases = [
    { state: 'rest', dur: 180 },
    { state: 'flow', dur: 240 },
    { state: 'burnout', dur: 120 },
    { state: 'flow', dur: 200 },
    { state: 'rest', dur: 160 },
  ];
  let phaseIdx = 0, phaseFrame = 0;

  // Fake landmark simulation
  function fakeHands() {
    const phase = demoPhases[phaseIdx % demoPhases.length];
    phaseFrame++;
    if (phaseFrame > phase.dur) { phaseFrame = 0; phaseIdx++; }

    const t = demoT * 0.02;
    const cx = arCanvas.width * 0.5, cy = arCanvas.height * 0.5;

    // Synthesize fake hand landmarks
    const fakeLMs = [];
    const spread = phase.state === 'rest' ? 0.04 :
                   phase.state === 'flow' ? 0.05 + Math.sin(t)*0.02 : 0.03;

    // 21 landmarks, rough hand shape
    const basePositions = [
      [0,0],[-.03,-.04],[-.03,-.07],[-.02,-.1],[-.01,-.13],
      [.02,-.05],[.02,-.09],[.02,-.12],[.02,-.15],
      [.04,-.05],[.04,-.09],[.04,-.13],[.04,-.16],
      [.06,-.04],[.06,-.08],[.06,-.11],[.06,-.14],
      [.08,-.03],[.08,-.06],[.08,-.09],[.08,-.12]
    ];

    const shake = phase.state === 'burnout' ? Math.sin(t*15)*0.008 : 0;
    const pinch = phase.state === 'flow' && Math.sin(t*4) > 0.5 ? 0.03 : 0;

    basePositions.forEach(([ox,oy], i) => {
      const nrmX = 0.5 + ox + Math.sin(t+i)*0.01 + shake;
      const nrmY = 0.5 + oy + Math.cos(t*0.7+i)*0.01 + shake;
      fakeLMs.push({ x: nrmX, y: nrmY, z: 0 });
    });

    // Apply pinch to thumb/index for flow
    if (pinch > 0) {
      fakeLMs[4].x = fakeLMs[8].x + 0.01;
      fakeLMs[4].y = fakeLMs[8].y + 0.01;
    }

    lastLandmarks = fakeLMs;
    const gesture = detectCrochetGesture(fakeLMs);
    if (pinch > 0) gesture.hook = true;
    if (phase.state === 'rest') gesture.openPalm = true;
    drawAROverlay(fakeLMs, gesture);

    // Simulate velocity
    velocity = phase.state === 'rest' ? 2 + Math.random()*2 :
               phase.state === 'flow' ? 15 + Math.sin(t)*8 :
               60 + Math.random()*20;

    demoT++;
    requestAnimationFrame(fakeHands);
  }
  fakeHands();
}

// Boot
document.addEventListener('DOMContentLoaded', () => {});
</script>
